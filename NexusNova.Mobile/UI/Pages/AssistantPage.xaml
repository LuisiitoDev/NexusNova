<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NexusNova.UI.Pages.AssistantPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:NexusNova.Domain.Models"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource DarkBackground}">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="16,52,16,12"
              BackgroundColor="{StaticResource DarkBackground}">

            <Border Grid.Column="0" Style="{StaticResource AvatarStyle}" Margin="0,0,12,0">
                <Label Text="L"
                       TextColor="White"
                       FontSize="17"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding UserName}"
                       Style="{StaticResource Body1Strong}"
                       TextColor="White"/>
                <HorizontalStackLayout Spacing="6">
                    <BoxView WidthRequest="7" HeightRequest="7"
                             CornerRadius="4"
                             Color="{StaticResource SyncedGreen}"
                             VerticalOptions="Center"/>
                    <Label Text="Sync Live"
                           Style="{StaticResource Caption1}"
                           TextColor="{StaticResource SyncedGreen}"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Border Grid.Column="2"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="1"
                    Stroke="#2200C8C8"
                    Background="#1100C8C8"
                    Padding="8"
                    VerticalOptions="Center">
                <Image Source="{StaticResource IconCloud}"
                       WidthRequest="20" HeightRequest="20"/>
            </Border>
        </Grid>

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Messages}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <BoxView HeightRequest="4" Color="Transparent"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatMessage">
                    <Grid Padding="16,0" ColumnDefinitions="Auto,*">

                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Background="#1A00C8C8"
                                Padding="6"
                                WidthRequest="36" HeightRequest="36"
                                VerticalOptions="Start"
                                Margin="0,0,10,0">
                            <Image Source="{StaticResource IconBot}"
                                   WidthRequest="20" HeightRequest="20"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Border Style="{StaticResource ChatBubbleStyle}">
                                <Label Text="{Binding Content}"
                                       Style="{StaticResource Body2}"
                                       TextColor="{StaticResource LightOnDarkBackground}"
                                       LineBreakMode="WordWrap"/>
                            </Border>
                            <Label Text="{Binding FormattedTime}"
                                   Style="{StaticResource Caption2}"
                                   TextColor="{StaticResource Gray500}"
                                   Margin="4,0,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <BoxView HeightRequest="8" Color="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Spacing="8" Padding="0,8,0,0"
                             BackgroundColor="{StaticResource DarkBackground}">
            <Grid ColumnDefinitions="*,Auto" Padding="16,0">
                <Label Grid.Column="0"
                       Text="SUGGESTED ACTIONS"
                       Style="{StaticResource Caption2}"
                       TextColor="{StaticResource Gray500}"
                       CharacterSpacing="1.5"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="Swipe right →"
                       Style="{StaticResource Caption2}"
                       TextColor="{StaticResource Gray600}"/>
            </Grid>

            <CollectionView
                ItemsSource="{Binding SuggestedActions}"
                HeightRequest="50"
                Margin="12,0">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SuggestedAction">
                        <Border Style="{StaticResource SuggestedChipStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSuggestedActionCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Image Source="{StaticResource IconWarning}"
                                       WidthRequest="14" HeightRequest="14"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ActionType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Warning}"/>
                                <Image Source="{StaticResource IconCalendarEvent}"
                                       WidthRequest="14" HeightRequest="14"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding ActionType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Calendar}"/>
                                <Label Text="{Binding Label}"
                                       Style="{StaticResource Caption1}"
                                       TextColor="{StaticResource LightOnDarkBackground}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto"
              Padding="16,8,16,24"
              BackgroundColor="{StaticResource DarkBackground}"
              ColumnSpacing="8">

            <Border Grid.Column="0" Style="{StaticResource InputBarStyle}">
                <Entry Placeholder="Schedule team sync tomorrow..."
                       PlaceholderColor="{StaticResource Gray500}"
                       TextColor="White"
                       Text="{Binding MessageInput}"
                       BackgroundColor="Transparent"
                       FontSize="15"
                       VerticalOptions="Center"
                       ReturnCommand="{Binding SendMessageCommand}"/>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SendButtonStyle}"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SendMessageCommand}"/>
                </Border.GestureRecognizers>
                <Image Source="{StaticResource IconSend}"
                       WidthRequest="18" HeightRequest="18"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
